{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Fix Issue Report",
  "type": "object",
  "required": ["issue_type", "severity", "description"],
  "properties": {
    "issue_type": {
      "type": "string",
      "enum": ["pdf_blank", "login_failed", "content_truncate", "other"],
      "description": "问题类型"
    },
    "severity": {
      "type": "string",
      "enum": ["critical", "major", "minor"],
      "description": "严重程度"
    },
    "description": {
      "type": "string",
      "description": "问题描述"
    },
    "root_cause": {
      "type": "string",
      "description": "根本原因"
    },
    "fix_steps": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "修复步骤"
    },
    "verification": {
      "type": "object",
      "properties": {
        "test_passed": {"type": "boolean"},
        "docs_updated": {"type": "boolean"}
      }
    }
  }
}
