{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "{YOUR_TEST_CMD} 2>&1 | tail -20"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "agent",
            "prompt": "运行完整测试套件确认所有测试通过。未通过前不结束，继续修复。",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
