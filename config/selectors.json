{
  "geekbang": {
    "article_content": [
      "[class*=\"article-content\"]",
      "[class*=\"article-body\"]",
      "[class*=\"contentWrap\"]",
      "[class*=\"Index_contentWrap\"]",
      "article",
      "main"
    ],
    "scroll_container": [
      "[class*=\"contentWrapper\"]",
      "[class*=\"scroller\"]",
      ".simplebar-content-wrapper"
    ],
    "sidebar": [
      "[class*=\"Index_side\"]",
      "[class*=\"sidebar\"]",
      "[class*=\"catalog\"]"
    ],
    "fixed_elements": {
      "classnames": ["modal", "popup", "overlay", "login-prompt"],
      "texts": ["登录", "注册", "推荐试读", "仅针对订阅"]
    },
    "exclude_classes": ["sidebar", "catalog", "menu", "nav", "list"]
  },
  "default": {
    "article_content": [
      "article",
      "main",
      ".content",
      ".post-content"
    ],
    "scroll_container": [
      "[class*=\"content\"]",
      "[class*=\"article\"]"
    ],
    "sidebar": [],
    "fixed_elements": {
      "classnames": ["modal", "popup", "overlay"],
      "texts": ["登录", "注册"]
    },
    "exclude_classes": ["sidebar", "catalog", "menu", "nav", "list"]
  }
}
